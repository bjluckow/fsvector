# Database
DATABASE_URL=postgres://fsvector:fsvector@postgres:5432/fsvector
# Text chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
MIN_CHUNK_SIZE=100

# Services (defaults match docker-compose service names)
EMBEDSVC_URL=http://embedsvc:8000
CONVERTSVC_URL=http://convertsvc:8001

# Daemon
WATCH_PATH=/data/source
EMBED_MODEL=clip-ViT-B-32
SOURCE=local
SOURCE_DIR=/path/to/your/files
MIN_EMBED_SIZE=100b